{
  "name": "jupiter-api-client",
  "version": "0.1.3",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm && bun run build:types",
    "build:types": "tsc --emitDeclarationOnly --declaration",
    "dev": "bun run src/index.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "keywords": [
    "jupiter",
    "jup",
    "api",
    "wrapper",
    "defi",
    "solana"
  ],
  "author": "snurfer0",
  "license": "MIT",
  "description": "TypeScript wrapper for Jupiter API with full type support",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snurfer0/jupiter-api-client.git"
  },
  "bugs": {
    "url": "https://github.com/snurfer0/jupiter-api-client/issues"
  },
  "homepage": "https://github.com/snurfer0/jupiter-api-client#readme"
}