# Scalperr - Environment variables (template)
# 
# Users: Copy this file to .env and add YOUR keys:
#   cp .env.example .env
# Then edit .env with your PRIVATE_KEY and optional API keys.
# .env is gitignored - it stays only on your machine and is never pushed.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
# Solana wallet private key as JSON array (e.g. from Phantom export)
PRIVATE_KEY=[1,2,3,...,64]

# ---------------------------------------------------------------------------
# Solana RPC
# ---------------------------------------------------------------------------
RPC_URL=https://api.mainnet-beta.solana.com
# RPC_WS_URL=wss://...

# ---------------------------------------------------------------------------
# Jupiter DEX (default: https://api.jup.ag)
# ---------------------------------------------------------------------------
JUPITER_API_URL=https://api.jup.ag

# ---------------------------------------------------------------------------
# Trading mode: dry (simulate) | live (real swaps)
# ---------------------------------------------------------------------------
TRADE_MODE=dry

# ---------------------------------------------------------------------------
# Execution
# ---------------------------------------------------------------------------
SLIPPAGE_BPS=50
MAX_EXEC_RETRIES=3
RETRY_DELAY_MS=1000
MIN_SOL_BALANCE_LAMPORTS=10000000

# ---------------------------------------------------------------------------
# Risk (override config/config.yaml)
# ---------------------------------------------------------------------------
# MAX_TRADE_PCT=0.1
# MIN_BALANCE_USD=100
# STOP_LOSS_PCT=2
# TAKE_PROFIT_PCT=1.5
# FIXED_NOTIONAL_USD=100

# ---------------------------------------------------------------------------
# Strategy
# ---------------------------------------------------------------------------
# MIN_CONFIDENCE_TO_EXECUTE=0.7
# WHALE_BULLISH_THRESHOLD=50

# ---------------------------------------------------------------------------
# Backtest
# ---------------------------------------------------------------------------
BACKTEST_SYMBOL=SOL
BACKTEST_INITIAL_BALANCE=10000

# ---------------------------------------------------------------------------
# Optional: Helius (on-chain analyzer), Grok (sentiment)
# ---------------------------------------------------------------------------
# HELIUS_API_KEY=
# HELIUS_URL=https://mainnet.helius-rpc.com
# GROK_API_KEY=
# X_BEARER_TOKEN=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=info
